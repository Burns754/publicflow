# ═══════════════════════════════════════════════
# PublicFlow Konfiguration — .env.example
# Kopiere diese Datei zu .env und fülle sie aus
# ═══════════════════════════════════════════════

# ── PFLICHTFELDER ──────────────────────────────

# JWT Secret (beliebiger langer zufälliger String)
JWT_SECRET=dein-geheimer-jwt-schluessel-mindestens-32-zeichen

# Frontend URL (für Stripe Redirect)
FRONTEND_URL=http://localhost:8000

# ── DATENBANK ──────────────────────────────────

# Standard: SQLite (lokal, kein Setup nötig)
DATABASE_URL=sqlite:///./publicflow.db

# Produktion: PostgreSQL (Railway stellt automatisch bereit)
# DATABASE_URL=postgresql://user:password@host:5432/publicflow

# ── KI-MATCHING (Optional aber empfohlen) ──────

# Claude AI für intelligentes Matching (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── STRIPE ZAHLUNGEN (Optional) ────────────────

# Stripe Keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Preis-IDs (aus Stripe Dashboard erstellen)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# ── E-MAIL (Optional) ──────────────────────────

# Resend für E-Mail-Versand (https://resend.com)
RESEND_API_KEY=re_...
FROM_EMAIL=PublicFlow <noreply@publicflow.io>

# ── RAILWAY HINWEISE ───────────────────────────
# Railway setzt DATABASE_URL und PORT automatisch.
# Unter "Variables" im Railway Dashboard eintragen:
#   JWT_SECRET, ANTHROPIC_API_KEY, STRIPE_*, RESEND_API_KEY
#   FRONTEND_URL=https://deine-app.up.railway.app
